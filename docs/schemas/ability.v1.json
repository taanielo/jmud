{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jmud:ability:v1",
  "title": "Ability (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "type",
    "level",
    "cooldown",
    "targeting",
    "effects"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["SKILL", "SPELL"]
    },
    "level": {
      "type": "integer",
      "minimum": 1
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "mana": {"type": "integer", "minimum": 0},
        "move": {"type": "integer", "minimum": 0},
        "mana_per_target": {"type": "integer", "minimum": 0}
      }
    },
    "cooldown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticks"],
      "properties": {
        "ticks": {"type": "integer", "minimum": 0}
      }
    },
    "targeting": {
      "type": "string",
      "enum": [
        "HARMFUL",
        "BENEFICIAL",
        "HARMFUL_OPENER",
        "BENEFICIAL_GROUP",
        "HARMFUL_UNDEAD",
        "AoE",
        "NONE"
      ]
    },
    "aliases": {
      "type": "array",
      "items": {"type": "string"}
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["VITALS", "EFFECT", "CURE"]
          },
          "stat": {
            "type": "string",
            "enum": ["HP", "MANA", "MOVE"]
          },
          "operation": {
            "type": "string",
            "enum": ["INCREASE", "DECREASE"]
          },
          "amount": {
            "type": "integer",
            "minimum": 1
          },
          "effect_id": {
            "type": "string",
            "pattern": "^[a-z0-9._-]+$"
          },
          "damage_type": {
            "type": "string",
            "enum": ["FIRE", "COLD", "POISON"],
            "description": "Optional elemental type of a damaging VITALS effect (case-insensitive). Omitted means untyped/physical: never resisted or amplified by a mob's elemental resistance/vulnerability. Only meaningful on a VITALS HP DECREASE effect."
          },
          "control": {
            "type": "string",
            "enum": ["ROOT", "SILENCE", "STUN"],
            "description": "Optional crowd-control classification a CURE effect strips instead of a fixed effect_id (case-insensitive). When present, the cure removes at most one active effect of that classification (ROOT/SILENCE/STUN) the ally carries, whichever it is; an ally with none is left untouched. Omitted preserves the effect_id-based cure. Only meaningful on a CURE effect."
          }
        },
        "allOf": [
          {
            "if": {"properties": {"kind": {"const": "VITALS"}}},
            "then": {"required": ["stat", "operation", "amount"]}
          },
          {
            "if": {"properties": {"kind": {"const": "EFFECT"}}},
            "then": {"required": ["effect_id"]}
          },
          {
            "if": {"properties": {"kind": {"const": "CURE"}}},
            "then": {"anyOf": [{"required": ["effect_id"]}, {"required": ["control"]}]}
          }
        ]
      }
    },
    "messages": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "self": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "room": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
