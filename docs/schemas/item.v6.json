{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jmud:item:v6",
  "title": "Item (v6)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "description",
    "attributes",
    "effects",
    "messages",
    "weight",
    "value"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 6
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "attributes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stats"
      ],
      "properties": {
        "stats": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        }
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "effect_id",
          "duration_ticks"
        ],
        "properties": {
          "effect_id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "duration_ticks": {
            "type": "integer",
            "minimum": 0
          },
          "op": {
            "type": "string",
            "enum": ["APPLY", "REMOVE"],
            "description": "Whether the item applies the effect (default) or removes it (a cure)."
          }
        }
      }
    },
    "messages": {
      "type": "array"
    },
    "equip_slot": {
      "type": "string",
      "enum": [
        "weapon",
        "offhand",
        "head",
        "chest",
        "legs",
        "hands",
        "feet"
      ]
    },
    "weight": {
      "type": "integer",
      "minimum": 0
    },
    "value": {
      "type": "integer",
      "minimum": 0
    },
    "attack_ref": {
      "type": "string",
      "pattern": "^[a-z0-9.-]+$",
      "description": "Id of the attack used when this item is equipped as a weapon."
    },
    "teaches_ability_ref": {
      "type": "string",
      "pattern": "^[a-z0-9.-]+$",
      "description": "Id of the ability learned by the player when this item (a scroll) is read."
    },
    "container_capacity": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum number of items this container can hold. Present only on container items (bags, chests, strongboxes); absent for normal items."
    },
    "contents": {
      "type": "array",
      "description": "Items currently stored inside this container. Absent or empty for empty containers and non-container items; contained items are never themselves containers.",
      "items": {
        "$ref": "#"
      }
    },
    "light_radius": {
      "type": "integer",
      "minimum": 1,
      "description": "Radius of light this item emits while carried. Present only on light-source items (torch = 1, lantern = 2); absent for non-light-emitting items. A carried light source lets its bearer see in dark rooms whose required light radius it meets or exceeds."
    }
  }
}
